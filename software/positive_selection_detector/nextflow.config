/*
 * Nextflow configuration for the positive-selection site-model pipeline.
 */

// Default process settings
process {
    // CodeML is CPU-bound and single-threaded; M8 and M8a run as
    // separate Nextflow processes so each gets 1 CPU.
    withName: 'RUN_CODEML_M8|RUN_CODEML_M8A' {
        cpus   = 1
        memory = '4 GB'
        time   = '24h'
    }
    withName: 'EXTRACT_RESULTS' {
        cpus   = 1
        memory = '2 GB'
        time   = '30m'
    }
    withName: 'FETCH_ALIGNMENT' {
        cpus   = 1
        memory = '2 GB'
        time   = '1h'
    }
    withName: 'FETCH_STRUCTURE' {
        cpus   = 1
        memory = '1 GB'
        time   = '30m'
    }
    withName: 'MERGE_PREPARE' {
        cpus   = 1
        memory = '512 MB'
        time   = '5m'
    }
    withName: 'ANALYZE_RESULTS' {
        cpus   = 1
        memory = '2 GB'
        time   = '30m'
    }
}

// Execution profiles
profiles {
    standard {
        process.executor = 'local'
    }
    slurm {
        process.executor = 'slurm'
    }
    conda {
        process.conda = "${projectDir}/environment.yml"
    }
}

// Timeline and report
timeline {
    enabled = true
    file    = "results/timeline.html"
    overwrite = true
}
report {
    enabled = true
    file    = "results/report.html"
    overwrite = true
}
